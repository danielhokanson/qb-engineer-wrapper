# ─── Ports ───
UI_PORT=4200
API_PORT=5000
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
AI_PORT=11434
TTS_PORT=5002
DOCUSEAL_PORT=3000

# ─── Database ───
POSTGRES_DB=qb_engineer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── API ───
ASPNETCORE_ENVIRONMENT=Development
RECREATE_DB=true
SEED_DEMO_DATA=true
SEED_USER_PASSWORD=
MOCK_INTEGRATIONS=true

# ─── JWT (REQUIRED — change in production) ───
JWT_KEY=dev-secret-key-change-in-production-min-32-chars!!
JWT_ISSUER=qb-engineer
JWT_AUDIENCE=qb-engineer-ui

# ─── MinIO (S3-compatible file storage) ───
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PUBLIC_ENDPOINT=localhost:9000

# ─── Storage provider: "minio" (default) or "local" ───
STORAGE_PROVIDER=minio
# LOCAL_STORAGE_PATH=./storage
# LOCAL_STORAGE_PUBLIC_URL=http://localhost:5000
# LOCAL_STORAGE_URL_EXPIRY=3600

# ─── Frontend ───
FRONTEND_BASE_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200

# ─── AI (optional — enable with: docker compose --profile ai up -d) ───
AI_BASE_URL=http://qb-engineer-ai:11434
AI_MODEL=gemma3:4b
AI_EMBEDDING_MODEL=all-minilm:l6-v2

# ─── TTS (optional — enable with: docker compose --profile tts up -d) ───
# TTS_API_KEY=             # OpenAI TTS API key (optional; Coqui used if unset)
# COQUI_BASE_URL=http://qb-engineer-tts:5002
# COQUI_SPEAKER_ID=p228

# ─── DocuSeal e-signatures (optional — enable with: docker compose --profile signing up -d) ───
# DOCUSEAL_BASE_URL=http://qb-engineer-signing:3000
# DOCUSEAL_PUBLIC_BASE_URL=http://localhost:4200/docuseal
# DOCUSEAL_API_KEY=
# DOCUSEAL_TIMEOUT=30
# DOCUSEAL_WEBHOOK_SECRET=
# DOCUSEAL_SECRET_KEY=change-me-in-production

# ─── USPS Address Validation (optional) ───
# USPS_CONSUMER_KEY=
# USPS_CONSUMER_SECRET=

# ─── SMTP Email Notifications (optional) ───
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# ─── Stamps.com Shipping (optional) ───
# STAMPS_API_KEY=
# STAMPS_ACCOUNT_ID=
# STAMPS_ENVIRONMENT=sandbox

# ─── Backup — Backblaze B2 (optional) ───
# BACKUP_B2_KEY_ID=
# BACKUP_B2_APP_KEY=
# BACKUP_B2_BUCKET=

# ─── Dev hot-reload (uncomment for development) ───
# COMPOSE_FILE=docker-compose.yml;docker-compose.dev.yml
