{
  "name": "qb-engineer-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "simulate": "playwright test --config=e2e/simulation/playwright.simulation.config.ts",
    "simulate:headed": "playwright test --config=e2e/simulation/playwright.simulation.config.ts --headed",
    "e2e:gen-docs": "playwright test --config=e2e/playwright.config.ts --grep generate-ui-docs --timeout 300000",
    "e2e:gen-docs:headed": "playwright test --config=e2e/playwright.config.ts --grep generate-ui-docs --timeout 300000 --headed",
    "e2e:gen-landmarks": "playwright test --config=e2e/playwright.config.ts --grep generate-ui-landmarks --timeout 300000",
    "e2e:gen-all": "npm run e2e:gen-docs && npm run e2e:gen-landmarks",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "audit:tours": "npx tsx scripts/audit-tours.ts",
    "lint": "ng lint",
    "lint:a11y": "npx eslint \"src/**/*.html\" --no-error-on-unmatched-pattern",
    "test:a11y": "npx cypress run --spec cypress/e2e/accessibility/a11y.cy.ts",
    "scenario": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts",
    "scenario:headed": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts --headed",
    "scenario:onboarding": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts --headed --grep \"01|02a|03a\"",
    "scenario:orders": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts --headed --grep \"01|02b|03b\"",
    "scenario:production": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts --headed --grep \"01|02c|03c\"",
    "scenario:expenses": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts --headed --grep \"01|02c|03d\"",
    "scenario:populate": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts --grep \"01|02d\"",
    "scenario:qb-sandbox": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts --headed --grep \"01|02e\"",
    "scenario:qb-clean": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts --headed --grep \"00\"",
    "scenario:qb-fresh": "playwright test --config=e2e/scenarios/playwright.scenarios.config.ts --headed --grep \"00|01|02e\"",
    "screenshots": "playwright test --config=e2e/screenshots/playwright.screenshots.config.ts",
    "screenshots:headed": "playwright test --config=e2e/screenshots/playwright.screenshots.config.ts --headed"
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.1",
    "@angular/material-date-fns-adapter": "^21.2.1",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.1",
    "@danielhokanson/ng-dynamic-forms-core": "^21.0.3",
    "@danielhokanson/ng-dynamic-forms-ui-material": "^21.0.3",
    "@fontsource-variable/alumni-sans-sc": "^5.2.3",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/raleway": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@microsoft/signalr": "^10.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/three": "^0.183.1",
    "angularx-qrcode": "^21.0.4",
    "bwip-js": "^4.8.0",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "driver.js": "^1.4.0",
    "gridstack": "^12.4.2",
    "html5-qrcode": "^2.3.8",
    "marked": "^17.0.4",
    "ng2-charts": "^10.0.0",
    "ngx-extended-pdf-viewer": "^25.6.4",
    "ngx-markdown": "^21.1.0",
    "ngx-mask": "^21.0.1",
    "ngx-quill": "^30.0.1",
    "papaparse": "^5.5.3",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "three": "^0.183.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.0",
    "@angular-eslint/eslint-plugin": "^21.3.0",
    "@angular-eslint/eslint-plugin-template": "^21.3.0",
    "@angular-eslint/schematics": "^21.3.0",
    "@angular-eslint/template-parser": "^21.3.0",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "angular-eslint": "^21.3.0",
    "axe-core": "^4.11.1",
    "cypress": "^15.11.0",
    "cypress-axe": "^1.7.0",
    "eslint": "^10.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.8"
  }
}
